<Window x:Class="StudentRegistrationSystem.Views.EnrollmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:StudentRegistrationSystem.Models"
        Title="Enrollment" Height="400" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Margin="18" Style="{StaticResource PanelBorderStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="Student" Width="160" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Students}"
                      SelectedItem="{Binding SelectedStudent}"
                      DisplayMemberPath="FullName"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="Course" Width="160" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Courses}"
                      SelectedItem="{Binding SelectedCourse}"
                      DisplayMemberPath="Title"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="Registration date" Width="160" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <DatePicker SelectedDate="{Binding Enrollment.RegisteredAt}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="Status" Width="160" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding StatusValues}"
                      SelectedItem="{Binding Enrollment.Status}"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,2">
            <TextBlock Text="Grade (0..10)" Width="160" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Enrollment.Grade, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,18,0,0">
            <Button Content="OK" IsDefault="True" Click="Ok_OnClick"/>
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
