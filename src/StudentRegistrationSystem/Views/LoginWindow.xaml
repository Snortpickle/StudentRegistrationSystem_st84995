<Window x:Class="StudentRegistrationSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudentRegistrationSystem.ViewModels"
        Title="Login" Height="330" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border Margin="18" Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Sign in"
                           FontWeight="SemiBold"
                           FontSize="24"/>
                <TextBlock Text="Demo credentials: admin / admin"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4">
                <TextBlock Text="Login" VerticalAlignment="Center" Width="110" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4">
                <TextBlock Text="Password" VerticalAlignment="Center" Width="110" FontWeight="SemiBold"/>
                <PasswordBox x:Name="Pwd" PasswordChanged="PasswordBox_OnPasswordChanged"/>
            </StackPanel>

            <Button Grid.Row="3"
                    Content="Log in"
                    Command="{Binding TryLoginCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="114,22,4,0"/>
        </Grid>
    </Border>
</Window>
