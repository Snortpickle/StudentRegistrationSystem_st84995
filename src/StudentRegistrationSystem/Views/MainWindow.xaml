<Window x:Class="StudentRegistrationSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudentRegistrationSystem.ViewModels"
        xmlns:models="clr-namespace:StudentRegistrationSystem.Models"
        Title="Student Registration System" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="Save XML" Command="{Binding SaveCommand}"/>
            <Button Content="Reload" Command="{Binding ReloadCommand}"/>
            <TextBlock Text="Student filters:" VerticalAlignment="Center" Margin="18,0,6,0"/>
            <TextBox Width="180" ToolTip="First/last name contains..." Text="{Binding StudentNameFilter, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Width="90" ToolTip="Group (e.g. IT-31)" Text="{Binding GroupFilter, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Width="60" ToolTip="Study year (1..6)" Text="{Binding StudyYearFilter, UpdateSourceTrigger=PropertyChanged}"/>
            <CheckBox Content="Scholarship only" IsChecked="{Binding OnlyScholarship}"/>
        </StackPanel>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0">
                <TabItem Header="Students">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Button Content="Add" Command="{Binding AddStudentCommand}"/>
                            <Button Content="Edit" Command="{Binding EditStudentCommand}"/>
                            <Button Content="Delete" Command="{Binding DeleteStudentCommand}"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding StudentsView}"
                                  SelectedItem="{Binding SelectedStudent}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="0,6,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Last name" Binding="{Binding LastName}" Width="*"/>
                                <DataGridTextColumn Header="First name" Binding="{Binding FirstName}" Width="*"/>
                                <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="Auto"/>
                                <DataGridTextColumn Header="Year" Binding="{Binding StudyYear}" Width="Auto"/>
                                <DataGridTextColumn Header="GPA" Binding="{Binding GPA, Converter={StaticResource FlexibleDoubleConverter}}" Width="Auto"/>
                                <DataGridCheckBoxColumn Header="Scholarship" Binding="{Binding HasScholarship}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Courses">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Add" Command="{Binding AddCourseCommand}"/>
                            <Button Content="Edit" Command="{Binding EditCourseCommand}"/>
                            <Button Content="Delete" Command="{Binding DeleteCourseCommand}"/>
                            <TextBlock Text="Department filter:" VerticalAlignment="Center" Margin="18,0,6,0"/>
                            <TextBox Width="120" Text="{Binding CourseDepartmentFilter, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding CoursesView}"
                                  SelectedItem="{Binding SelectedCourse}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="0,6,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                                <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="*"/>
                                <DataGridTextColumn Header="Credits" Binding="{Binding Credits}" Width="Auto"/>
                                <DataGridTextColumn Header="Max" Binding="{Binding MaxStudents}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Enrollments">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Button Content="Add" Command="{Binding AddEnrollmentCommand}"/>
                            <Button Content="Edit" Command="{Binding EditEnrollmentCommand}"/>
                            <Button Content="Delete" Command="{Binding DeleteEnrollmentCommand}"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding EnrollmentsView}"
                                  SelectedItem="{Binding SelectedEnrollment}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="0,6,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="StudentId" Binding="{Binding StudentId}" Width="2*"/>
                                <DataGridTextColumn Header="CourseId" Binding="{Binding CourseId}" Width="2*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding RegisteredAt}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Margin="6" TextWrapping="Wrap"
                                   Text="*For simplicity, only StudentId and CourseId are shown. In a real project you could display names via a converter or a dedicated ViewModel."/>
                    </DockPanel>
                </TabItem>
            </TabControl>

            <GroupBox Grid.Column="1" Header="Calculations / statistics" Margin="10,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding StatsText}" Margin="10" FontFamily="Consolas"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
